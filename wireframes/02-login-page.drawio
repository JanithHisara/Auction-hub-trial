<mxfile host="app.diagrams.net">
  <diagram name="Login Page" id="login-page">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="800" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Browser Frame -->
        <mxCell id="frame" value="" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#0a0a0a;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="720" height="620" as="geometry" />
        </mxCell>
        
        <!-- Navbar -->
        <mxCell id="navbar" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1a1a1a;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="720" height="60" as="geometry" />
        </mxCell>
        <mxCell id="logo" value="LUXBID Reserve" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#D4AF37;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="60" y="55" width="150" height="30" as="geometry" />
        </mxCell>
        <mxCell id="nav-links" value="LOGIN | ACCESS" style="text;html=1;strokeColor=none;fillColor=none;align=right;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#888888;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="600" y="55" width="140" height="30" as="geometry" />
        </mxCell>
        
        <!-- Login Form Card -->
        <mxCell id="form-card" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a1a;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="200" y="150" width="400" height="450" as="geometry" />
        </mxCell>
        
        <!-- Decorative Corner -->
        <mxCell id="corner" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D4AF37;strokeColor=none;opacity=20;" vertex="1" parent="1">
          <mxGeometry x="540" y="150" width="60" height="60" as="geometry" />
        </mxCell>
        
        <!-- Shield Icon -->
        <mxCell id="icon-box" value="🛡" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#222222;strokeColor=#333333;fontSize=24;" vertex="1" parent="1">
          <mxGeometry x="360" y="175" width="80" height="50" as="geometry" />
        </mxCell>
        
        <!-- Title -->
        <mxCell id="title" value="AUTHORIZED ACCESS" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#ffffff;fontStyle=1;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="250" y="240" width="300" height="30" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Enter credentials to proceed" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#888888;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="250" y="270" width="300" height="20" as="geometry" />
        </mxCell>
        
        <!-- Email Field -->
        <mxCell id="email-label" value="IDENTITY / EMAIL" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#888888;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="240" y="310" width="120" height="20" as="geometry" />
        </mxCell>
        <mxCell id="email-field" value="✉  name@domain.com" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#0a0a0a;strokeColor=#333333;align=left;fontColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="240" y="330" width="320" height="45" as="geometry" />
        </mxCell>
        
        <!-- Password Field -->
        <mxCell id="pass-label" value="SECURITY KEY" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#888888;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="240" y="390" width="120" height="20" as="geometry" />
        </mxCell>
        <mxCell id="pass-field" value="🔒  ••••••••" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#0a0a0a;strokeColor=#333333;align=left;fontColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="240" y="410" width="320" height="45" as="geometry" />
        </mxCell>
        
        <!-- Submit Button -->
        <mxCell id="submit-btn" value="ACCESS TERMINAL  →" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D4AF37;strokeColor=none;fontColor=#000000;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="240" y="480" width="320" height="50" as="geometry" />
        </mxCell>
        
        <!-- Divider -->
        <mxCell id="divider" value="" style="line;strokeWidth=1;fillColor=none;align=left;verticalAlign=middle;spacingTop=-1;spacingLeft=3;spacingRight=3;rotatable=0;labelPosition=right;points=[];portConstraint=eastwest;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="240" y="550" width="320" height="10" as="geometry" />
        </mxCell>
        
        <!-- Register Link -->
        <mxCell id="register-link" value="REQUEST NEW ACCESS CREDENTIALS" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#888888;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="250" y="565" width="300" height="25" as="geometry" />
        </mxCell>
        
        <!-- Page Title -->
        <mxCell id="page-title" value="LOGIN PAGE" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#333333;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="10" width="200" height="25" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

