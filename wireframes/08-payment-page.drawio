<mxfile host="app.diagrams.net">
  <diagram name="Payment Page" id="payment-page">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Browser Frame -->
        <mxCell id="frame" value="" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#666666;fillColor=#f8f7f5;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="820" height="620" as="geometry" />
        </mxCell>
        
        <!-- Navbar -->
        <mxCell id="navbar" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1a1a1a;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="820" height="60" as="geometry" />
        </mxCell>
        <mxCell id="logo" value="LUXBID Reserve" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontColor=#D4AF37;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="60" y="55" width="150" height="30" as="geometry" />
        </mxCell>
        
        <!-- Payment Card -->
        <mxCell id="payment-card" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#E8E0D0;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="130" width="500" height="500" as="geometry" />
        </mxCell>
        
        <!-- Title -->
        <mxCell id="title" value="Complete Payment" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontColor=#333333;fontStyle=1;fontSize=24;" vertex="1" parent="1">
          <mxGeometry x="230" y="155" width="300" height="40" as="geometry" />
        </mxCell>
        
        <!-- Gem Info Box -->
        <mxCell id="gem-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f7f5;strokeColor=#D4AF37;" vertex="1" parent="1">
          <mxGeometry x="230" y="210" width="440" height="100" as="geometry" />
        </mxCell>
        <mxCell id="gem-name" value="Blue Sapphire Ring" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontColor=#333333;fontStyle=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="250" y="225" width="300" height="30" as="geometry" />
        </mxCell>
        <mxCell id="winning-label" value="Winning Bid:" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontColor=#888888;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="250" y="265" width="100" height="25" as="geometry" />
        </mxCell>
        <mxCell id="winning-amount" value="$12,500" style="text;html=1;strokeColor=none;fillColor=none;align=right;verticalAlign=middle;fontColor=#8B7355;fontStyle=1;fontSize=20;" vertex="1" parent="1">
          <mxGeometry x="500" y="260" width="150" height="30" as="geometry" />
        </mxCell>
        
        <!-- Card Number -->
        <mxCell id="card-label" value="Card Number" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontColor=#888888;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="230" y="330" width="100" height="20" as="geometry" />
        </mxCell>
        <mxCell id="card-input" value="4242 4242 4242 4242" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#E8E0D0;align=left;fontColor=#333333;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="230" y="350" width="440" height="45" as="geometry" />
        </mxCell>
        
        <!-- Expiry & CVC Row -->
        <mxCell id="exp-label" value="Expiry Date" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontColor=#888888;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="230" y="410" width="100" height="20" as="geometry" />
        </mxCell>
        <mxCell id="exp-input" value="12 / 25" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#E8E0D0;align=left;fontColor=#333333;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="230" y="430" width="200" height="45" as="geometry" />
        </mxCell>
        <mxCell id="cvc-label" value="CVC" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontColor=#888888;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="470" y="410" width="50" height="20" as="geometry" />
        </mxCell>
        <mxCell id="cvc-input" value="***" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#E8E0D0;align=left;fontColor=#333333;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="470" y="430" width="200" height="45" as="geometry" />
        </mxCell>
        
        <!-- Pay Button -->
        <mxCell id="pay-btn" value="Pay $12,500 →" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#8B7355;strokeColor=none;fontColor=#ffffff;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="230" y="510" width="440" height="55" as="geometry" />
        </mxCell>
        
        <!-- Secure Badge -->
        <mxCell id="secure-badge" value="🔒 Secure payment powered by Stripe" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontColor=#888888;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="300" y="580" width="300" height="25" as="geometry" />
        </mxCell>
        
        <!-- Page Title -->
        <mxCell id="page-title" value="PAYMENT PAGE - Winner Payment Form" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontColor=#333333;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="10" width="300" height="25" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

