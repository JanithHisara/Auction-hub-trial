<mxfile host="app.diagrams.net">
  <diagram name="Monitor Page" id="monitor-page">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Browser Frame (Full screen dark) -->
        <mxCell id="frame" value="" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=#333333;fillColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="1320" height="720" as="geometry" />
        </mxCell>
        
        <!-- Header -->
        <mxCell id="header" value="LIVE AUCTION MONITOR" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#D4AF37;fontStyle=1;fontSize=28;letterSpacing=10px;" vertex="1" parent="1">
          <mxGeometry x="350" y="70" width="700" height="50" as="geometry" />
        </mxCell>
        
        <!-- Left Panel - Current Price -->
        <mxCell id="left-panel" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#111111;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="80" y="150" width="580" height="450" as="geometry" />
        </mxCell>
        
        <mxCell id="price-label" value="CURRENT PRICE" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#666666;fontSize=18;letterSpacing=5px;" vertex="1" parent="1">
          <mxGeometry x="200" y="190" width="340" height="40" as="geometry" />
        </mxCell>
        
        <mxCell id="price-value" value="$12,500" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#D4AF37;fontStyle=1;fontSize=72;" vertex="1" parent="1">
          <mxGeometry x="140" y="250" width="460" height="100" as="geometry" />
        </mxCell>
        
        <!-- Round Timer -->
        <mxCell id="round-label" value="NEXT ROUND IN" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#555555;fontSize=12;letterSpacing=3px;" vertex="1" parent="1">
          <mxGeometry x="250" y="380" width="240" height="30" as="geometry" />
        </mxCell>
        <mxCell id="round-timer" value="01:45" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#ffffff;fontStyle=1;fontSize=48;" vertex="1" parent="1">
          <mxGeometry x="250" y="410" width="240" height="60" as="geometry" />
        </mxCell>
        
        <!-- Active Bidders Badge -->
        <mxCell id="bidders-badge" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a1a;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="230" y="500" width="280" height="50" as="geometry" />
        </mxCell>
        <mxCell id="bidders-dot" value="●" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#22c55e;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="250" y="505" width="30" height="40" as="geometry" />
        </mxCell>
        <mxCell id="bidders-text" value="8 Active Bidders" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#cccccc;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="290" y="505" width="200" height="40" as="geometry" />
        </mxCell>
        
        <!-- Right Panel - Participation Rate -->
        <mxCell id="right-panel" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#111111;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="740" y="150" width="580" height="450" as="geometry" />
        </mxCell>
        
        <mxCell id="rate-label" value="PARTICIPATION RATE" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#666666;fontSize=18;letterSpacing=5px;" vertex="1" parent="1">
          <mxGeometry x="850" y="190" width="360" height="40" as="geometry" />
        </mxCell>
        
        <!-- Progress Bar -->
        <mxCell id="progress-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a1a;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="790" y="280" width="480" height="40" as="geometry" />
        </mxCell>
        <mxCell id="progress-fill" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D4AF37;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="790" y="280" width="350" height="40" as="geometry" />
        </mxCell>
        <mxCell id="progress-labels" value="0%                                        72%                                       100%" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#666666;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="790" y="330" width="480" height="30" as="geometry" />
        </mxCell>
        
        <!-- Participation Stats -->
        <mxCell id="part-stats" value="8" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#ffffff;fontStyle=1;fontSize=64;" vertex="1" parent="1">
          <mxGeometry x="910" y="400" width="100" height="80" as="geometry" />
        </mxCell>
        <mxCell id="part-slash" value="/" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#444444;fontSize=48;" vertex="1" parent="1">
          <mxGeometry x="1000" y="410" width="40" height="70" as="geometry" />
        </mxCell>
        <mxCell id="part-total" value="11" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#666666;fontSize=42;" vertex="1" parent="1">
          <mxGeometry x="1030" y="420" width="80" height="60" as="geometry" />
        </mxCell>
        <mxCell id="part-label" value="REGISTERED USERS PARTICIPATING" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#555555;fontSize=11;letterSpacing=2px;" vertex="1" parent="1">
          <mxGeometry x="850" y="500" width="360" height="30" as="geometry" />
        </mxCell>
        
        <!-- Footer Status -->
        <mxCell id="status-badge" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#111111;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="560" y="640" width="280" height="50" as="geometry" />
        </mxCell>
        <mxCell id="status-label" value="STATUS" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#555555;fontSize=12;letterSpacing=3px;" vertex="1" parent="1">
          <mxGeometry x="600" y="650" width="80" height="30" as="geometry" />
        </mxCell>
        <mxCell id="status-value" value="ACTIVE" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#22c55e;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="710" y="650" width="100" height="30" as="geometry" />
        </mxCell>
        
        <!-- Page Title -->
        <mxCell id="page-title" value="MONITOR PAGE - Live TV Display (Full Screen, Dark Theme)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#333333;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="10" width="450" height="25" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

